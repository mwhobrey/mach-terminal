{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mach Terminal",
  "version": "0.1.0",
  "identifier": "com.machbox.terminal",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "devUrl": "http://localhost:17430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": false,
      "pubkey": "",
      "endpoints": []
    },
    "deep-link": {
      "desktop": {
        "schemes": ["machterm"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mach Terminal",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Mach Terminal is a fast local-first desktop terminal.",
    "longDescription": "Mach Terminal is a local-first, speed-focused desktop terminal with optional bring-your-own-provider AI features.",
    "publisher": "MachBox",
    "copyright": "Copyright (c) 2026 MachBox",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
