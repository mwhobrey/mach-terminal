{
  "name": "mach-terminal",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "node scripts/dev-with-cleanup.mjs",
    "build": "tsc && vite build",
    "test": "npm run test:types && npm run test:ux && npm run test:perf && npm run test:pty",
    "test:types": "tsc --noEmit",
    "test:ux": "vitest run",
    "test:ux:smoke": "vitest run smoke.test.ts",
    "test:invoke:smoke": "node scripts/invoke-smoke.mjs",
    "test:invoke:strict": "node scripts/invoke-smoke.mjs --strict",
    "test:pty": "cargo test --manifest-path src-tauri/Cargo.toml --tests",
    "test:perf": "cargo test --manifest-path src-tauri/Cargo.toml --release --lib pty_byte_pipeline_round_trips -- --nocapture",
    "security:npm": "npm audit --omit=dev --audit-level=high",
    "security:cargo": "cargo audit -f src-tauri/Cargo.lock",
    "security:gitleaks": "gitleaks detect --source . --verbose",
    "security:baseline": "npm run security:npm && npm run security:cargo",
    "check:versions": "node scripts/check-version-sync.mjs",
    "release:setup-signing": "pwsh -File scripts/setup-release-signing.ps1",
    "release:smoke": "node scripts/release-smoke.mjs",
    "release:build": "npm run check:versions && npm run build && npm run tauri -- build",
    "release:artifacts": "node scripts/list-release-artifacts.mjs",
    "release:dry-run": "node scripts/release-dry-run.mjs",
    "stability:signoff": "node scripts/stability-signoff.mjs",
    "burnin:nightly": "node scripts/nightly-burnin.mjs",
    "burnin:gate": "node scripts/threshold-gates.mjs",
    "burnin:calibrate": "node scripts/calibrate-thresholds.mjs",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.4"
  }
}
